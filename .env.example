# =============================================================================
# Horilla HRMS — Environment Variables
# Copy this file to .env and fill in ALL values before deploying.
# NEVER commit .env to git.
# =============================================================================

# ── Django Core ───────────────────────────────────────────────────────────────
SECRET_KEY=your-very-long-random-secret-key-replace-this
DEBUG=False
ALLOWED_HOSTS=yourdomain.com,www.yourdomain.com,your-lb-dns.amazonaws.com
CSRF_TRUSTED_ORIGINS=https://yourdomain.com,https://www.yourdomain.com
DJANGO_SETTINGS_MODULE=horilla.settings

# ── CORS (Cross-Origin Resource Sharing) ─────────────────────────────────────
# Comma-separated list of allowed origins for /api/* endpoints.
# Leave blank to disallow all cross-origin API requests (recommended if no mobile app).
# Example: CORS_ALLOWED_ORIGINS=https://app.example.com,https://mobile.example.com
CORS_ALLOWED_ORIGINS=

# ── Database Initialization ───────────────────────────────────────────────────
# Password required to load demo data or initialize the database via the UI.
# REQUIRED — no default. Generate with:
#   python -c "import secrets; print(secrets.token_hex(32))"
DB_INIT_PASSWORD=

# ── wkhtmltopdf (PDF generation) ─────────────────────────────────────────────
# Docker/Linux path — auto-detected if left blank
WKHTMLTOPDF_PATH=/usr/bin/wkhtmltopdf

# ── Database (NeonDB) ─────────────────────────────────────────────────────────
DATABASE_URL=postgresql://user:password@ep-xxx.us-east-1.aws.neon.tech/horilla?sslmode=require

# ── Redis ─────────────────────────────────────────────────────────────────────
CELERY_BROKER_URL=redis://redis:6379/0
CACHE_REDIS_URL=redis://redis:6379/1

# ── AWS S3 (Media & Static Files) ────────────────────────────────────────────
AWS_ACCESS_KEY_ID=AKIAIOSFODNN7EXAMPLE
AWS_SECRET_ACCESS_KEY=wJalrXUtnFEMI/K7MDENG/bPxRfiCYEXAMPLEKEY
AWS_STORAGE_BUCKET_NAME=horilla-hrms-media
AWS_S3_REGION_NAME=us-east-1
AWS_S3_CUSTOM_DOMAIN=
# Set to True to serve static files from S3 too
USE_S3=True

# ── Admin User (created on first boot) ───────────────────────────────────────
ADMIN_FIRST_NAME=Admin
ADMIN_LAST_NAME=User
ADMIN_USERNAME=admin
ADMIN_PASSWORD=ChangeMe123!
ADMIN_EMAIL=admin@yourdomain.com
ADMIN_PHONE=0000000000

# ── Email (SMTP) ──────────────────────────────────────────────────────────────
EMAIL_HOST=smtp.sendgrid.net
EMAIL_PORT=587
EMAIL_HOST_USER=apikey
EMAIL_HOST_PASSWORD=SG.your-sendgrid-api-key
EMAIL_USE_TLS=True
DEFAULT_FROM_EMAIL=noreply@yourdomain.com

# ── Gunicorn ──────────────────────────────────────────────────────────────────
PORT=8000
WEB_CONCURRENCY=9

# ── Celery ────────────────────────────────────────────────────────────────────
CELERY_CONCURRENCY=4
CELERY_LOG_LEVEL=info
CELERY_MAX_TASKS=50
