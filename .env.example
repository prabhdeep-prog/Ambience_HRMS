# ─────────────────────────────────────────────────────────────────────────────
# Horilla HRMS — environment variable template
#
# Copy this file to .env and fill in every value before running the app.
#   cp .env.example .env
#
# .env is git-ignored and must NEVER be committed to version control.
# ─────────────────────────────────────────────────────────────────────────────


# ── Django core ──────────────────────────────────────────────────────────────

# Required. No default — the app refuses to start without this.
# Generate with:
#   python -c "from django.core.management.utils import get_random_secret_key; print(get_random_secret_key())"
SECRET_KEY=

# Set to True only during local development. Never True in production.
DEBUG=False

# Comma-separated list of hostnames Django will serve.
# Example: ALLOWED_HOSTS=yourdomain.com,www.yourdomain.com
ALLOWED_HOSTS=127.0.0.1,localhost

# Comma-separated list of trusted origins for CSRF.
# Must include the scheme (http:// or https://).
# Example: CSRF_TRUSTED_ORIGINS=https://yourdomain.com
CSRF_TRUSTED_ORIGINS=http://localhost:8000


# ── Database ─────────────────────────────────────────────────────────────────

# Full database connection URL (takes priority over individual DB_* vars).
# Format: postgres://USER:PASSWORD@HOST:PORT/NAME
DATABASE_URL=postgres://horilla_user:changeme@localhost:5432/horilla

# Used by docker-compose to create the PostgreSQL container.
POSTGRES_DB=horilla
POSTGRES_USER=horilla_user
POSTGRES_PASSWORD=


# ── Admin bootstrap (used by entrypoint.sh on first start) ──────────────────

ADMIN_FIRST_NAME=Admin
ADMIN_LAST_NAME=User
ADMIN_USERNAME=
ADMIN_EMAIL=
# Generate with: openssl rand -base64 32
ADMIN_PASSWORD=
ADMIN_PHONE=0000000000


# ── Timezone ─────────────────────────────────────────────────────────────────

TIME_ZONE=UTC


# ── Biometric credential encryption ─────────────────────────────────────────

# Required when the biometric module is enabled.
# Encrypts zk_password, bio_username, bio_password, api_key, api_secret, api_token
# at rest using Fernet symmetric encryption (AES-128-CBC + HMAC-SHA256).
#
# Generate with:
#   python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
#
# Store this key in a secrets manager (AWS Secrets Manager, GCP Secret Manager,
# HashiCorp Vault) for production. Losing it makes all encrypted rows unreadable.
FIELD_ENCRYPTION_KEY=


# ── Cache / throttling (optional, defaults to in-memory) ─────────────────────

# Recommended for production to persist throttle counters across restarts.
REDIS_URL=redis://localhost:6379/1


# ── Cloud storage (optional) ─────────────────────────────────────────────────

# Uncomment and fill in to use AWS S3 instead of local media storage.
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=
# AWS_STORAGE_BUCKET_NAME=
# AWS_S3_REGION_NAME=

# Uncomment and fill in to use Google Cloud Storage.
# GS_BUCKET_NAME=
# GS_PROJECT_ID=
